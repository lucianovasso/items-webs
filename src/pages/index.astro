<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:       #0C0C0B;
  --bg-2:     #111110;
  --bg-3:     #161614;
  --border:   rgba(255,255,255,.07);
  --border-2: rgba(255,255,255,.12);
  --text:     #E8E6E1;
  --muted:    #7A776E;
  --muted-2:  #4A4843;
  --accent:   #5d60d3;
  --accent-2: #4547a8;
  --mono: 'Chakra Petch', sans-serif;
  --sans: 'Courier New', Courier, monospace;
}

html { scroll-behavior: smooth; }

body {
  font-family: var(--sans);
  font-weight: 400;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}
img, svg { max-width: 100%; height: auto; }
* { -webkit-tap-highlight-color: transparent; }

::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--muted-2); }

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  height: 60px;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 2.5rem;
  border-bottom: 1px solid transparent;
  transition: border-color .3s, background .3s;
}
nav.scrolled {
  background: rgba(12,12,11,.92);
  backdrop-filter: blur(12px);
  border-color: var(--border);
}

.nav-logo {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none;
}
.nav-logo .logo-icon { width: 30px; height: 27px; }
.nav-logo-text {
  font-family: var(--mono);
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--text);
  letter-spacing: -0.02em;
}
.nav-logo-text span { color: var(--accent); animation: pulse 2s ease infinite; }

.nav-links {
  display: flex; align-items: center; gap: 2rem; list-style: none;
}
.nav-links a {
  font-family: var(--mono);
  font-size: .7rem;
  font-weight: 300;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
  transition: color .2s;
}
.nav-links a:hover { color: var(--text); }

.nav-cta {
  font-family: var(--mono);
  font-size: .7rem;
  font-weight: 600;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: #ffffff;
  background: var(--accent);
  text-decoration: none;
  padding: .45rem 1.2rem;
  transition: background .2s;
}
.nav-cta:hover { background: var(--accent-2); }

/* ── TICKER ── */
.ticker-bar {
  position: fixed; top: 60px; left: 0; right: 0; z-index: 99;
  height: 28px;
  background: var(--bg-2);
  border-bottom: 1px solid var(--border);
  overflow: hidden;
  display: flex; align-items: center;
}
.ticker-track {
  display: flex; gap: 0;
  animation: ticker 40s linear infinite;
  white-space: nowrap;
}
.ticker-item {
  font-family: var(--mono);
  font-size: .6rem;
  font-weight: 300;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--muted);
  padding: 0 2rem;
}
.ticker-item .dot { color: var(--accent); margin-right: .6rem; }
.ticker-item .val { color: var(--muted); }
@keyframes ticker {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ── HERO ── */
.hero {
  min-height: 100vh;
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: 0 2.5rem 5rem;
  padding-top: 88px;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 70% 40%, rgba(200,240,96,.06) 0%, transparent 70%),
    radial-gradient(ellipse 40% 60% at 20% 80%, rgba(200,240,96,.03) 0%, transparent 60%);
}

.hero-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 0%, transparent 100%);
  opacity: .4;
}

.hero-status {
  display: inline-flex; align-items: center; gap: .6rem;
  font-family: var(--mono);
  font-size: .62rem;
  font-weight: 300;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 1.8rem;
  opacity: 0;
  animation: fadeUp .6s .1s ease forwards;
}
.hero-status-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 8px rgba(93,96,211,.6);
  animation: pulse 2s ease infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: .4; }
}

.hero-title {
  font-family: var(--mono);
  font-size: clamp(2.2rem, 5.5vw, 4.8rem);
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.03em;
  color: var(--accent);
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: fadeUp .6s .25s ease forwards;
}
.hero-title span { color: var(--accent); }
.hero-title .line-muted { color: var(--muted); font-weight: 300; }

.hero-tagline {
  font-size: clamp(.85rem, 1.4vw, 1rem);
  font-weight: 300;
  color: var(--muted);
  border-left: 1px solid rgba(93,96,211,.35);
  padding-left: .9rem;
  margin-bottom: 1.4rem;
  letter-spacing: .01em;
  opacity: 0;
  animation: fadeUp .6s .4s ease forwards;
}

.hero-sub {
  font-size: clamp(.85rem, 1.4vw, 1rem);
  font-weight: 400;
  color: var(--muted);
  max-width: 520px;
  line-height: 1.8;
  margin-bottom: 2.5rem;
  opacity: 0;
  animation: fadeUp .6s .4s ease forwards;
}
.hero-sub strong { color: var(--text); font-weight: 400; }

.hero-actions {
  display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;
  opacity: 0;
  animation: fadeUp .6s .55s ease forwards;
}

.btn-primary {
  font-family: var(--mono);
  font-size: .75rem;
  font-weight: 600;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: #ffffff;
  background: var(--accent);
  text-decoration: none;
  padding: .85rem 1.8rem;
  border: 1px solid transparent;
  transition: background .2s;
  display: inline-flex; align-items: center; gap: .6rem;
}
.btn-primary:hover { background: var(--accent-2); }

.btn-secondary {
  font-family: var(--mono);
  font-size: .75rem;
  font-weight: 300;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--muted);
  background: transparent;
  text-decoration: none;
  padding: .85rem 1.8rem;
  border: 1px solid var(--border-2);
  transition: color .2s, border-color .2s;
}
.btn-secondary:hover { color: var(--text); border-color: var(--muted); }

.hero-stats {
  position: absolute; right: 2.5rem; bottom: 5rem;
  display: flex; flex-direction: column; gap: 1.2rem;
  opacity: 0;
  animation: fadeUp .6s .7s ease forwards;
}
.hero-stat { text-align: right; }
.hero-stat-num {
  font-family: var(--mono);
  font-size: 1.6rem;
  font-weight: 700;
  color: var(--text);
  line-height: 1;
}
.hero-stat-num span { color: var(--accent); }
.hero-stat-label {
  font-family: var(--mono);
  font-size: .58rem;
  font-weight: 300;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--muted-2);
  margin-top: .2rem;
}

.hero-scroll {
  position: absolute; bottom: 2rem; left: 2.5rem;
  font-family: var(--mono);
  font-size: .58rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--muted-2);
  opacity: 0;
  animation: fadeUp .6s .9s ease forwards;
  display: flex; align-items: center; gap: .6rem;
}
.hero-scroll::before {
  content: '';
  display: block;
  width: 24px; height: 1px;
  background: var(--muted-2);
}

/* ── SECTIONS ── */
section {
  padding: 7rem 2.5rem;
  border-top: 1px solid var(--border);
}

.section-label {
  font-family: var(--mono);
  font-size: .62rem;
  font-weight: 300;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1rem;
  display: flex; align-items: center; gap: .8rem;
}
.section-label::before {
  content: '';
  display: block;
  width: 16px; height: 1px;
  background: var(--accent);
}

.section-title {
  font-family: var(--mono);
  font-size: clamp(1.6rem, 3vw, 2.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--text);
  margin-bottom: .6rem;
  line-height: 1.15;
}

.section-sub {
  font-size: .9rem;
  font-weight: 400;
  color: var(--muted);
  max-width: 440px;
  line-height: 1.8;
}

/* ── SERVICIOS ── */
.servicios-header {
  max-width: 1100px; margin: 0 auto 3.5rem;
  display: flex; justify-content: space-between; align-items: flex-end;
  flex-wrap: wrap; gap: 1rem;
}

.servicios-grid {
  max-width: 1100px; margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
}

.servicio-card {
  background: var(--bg);
  padding: 2.5rem 2rem;
  display: flex; flex-direction: column;
  transition: background .25s;
  position: relative;
  overflow: hidden;
}
.servicio-card:hover { background: var(--bg-3); }
.servicio-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--accent);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .3s ease;
}
.servicio-card:hover::before { transform: scaleX(1); }

.servicio-num {
  font-family: var(--mono);
  font-size: .6rem;
  font-weight: 300;
  color: var(--muted-2);
  letter-spacing: .14em;
  margin-bottom: 2rem;
}
.servicio-icon {
  font-size: 1.3rem;
  margin-bottom: 1.5rem;
  line-height: 1;
  color: var(--muted-2);
  transition: color .3s;
}
.servicio-card:hover .servicio-icon { color: var(--accent); }
.servicio-title {
  font-family: var(--mono);
  font-size: .95rem;
  font-weight: 600;
  color: var(--text);
  margin-bottom: .8rem;
  letter-spacing: -0.01em;
}
.servicio-desc {
  font-size: .82rem;
  font-weight: 400;
  color: var(--muted);
  line-height: 1.75;
  flex: 1;
}
.servicio-items {
  margin-top: 1.5rem;
  display: flex; flex-direction: column; gap: .4rem;
}
.servicio-item {
  font-family: var(--mono);
  font-size: .68rem;
  font-weight: 300;
  color: var(--muted-2);
  display: flex; align-items: center; gap: .5rem;
}
.servicio-item::before {
  content: '→';
  color: var(--accent);
  font-size: .62rem;
  flex-shrink: 0;
}
.servicio-item--highlight {
  color: var(--text);
  border-left: 1px solid var(--accent);
  padding-left: .6rem;
}
.servicio-item--highlight::before { display: none; }

/* ── DIFERENCIAL ── */
.dif-block { max-width: 1100px; margin: 0 auto; }
.dif-header {
  margin-bottom: 3rem;
  display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: end;
}
.dif-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; background: var(--border);
  border: 1px solid var(--border);
  margin-bottom: 1px;
}
.dif-grid-bottom {
  display: grid; grid-template-columns: 2fr 1fr;
  gap: 1px; background: var(--border);
  border: 1px solid var(--border);
  border-top: none;
}
.dif-cell { background: var(--bg-2); padding: 2rem; }
.dif-cell-accent { background: var(--bg-3); border-left: 2px solid var(--accent); }
.dif-cell-large { padding: 2.5rem; }
.dif-cell-num {
  font-family: var(--mono);
  font-size: 2.8rem;
  font-weight: 700;
  color: var(--accent);
  line-height: 1;
  margin-bottom: .4rem;
}
.dif-cell-label {
  font-family: var(--mono);
  font-size: .62rem;
  font-weight: 300;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--muted-2);
  margin-bottom: .8rem;
}
.dif-cell-text { font-size: .82rem; color: var(--muted); line-height: 1.7; }
.dif-cell-quote {
  font-size: 1.15rem;
  font-weight: 400;
  color: var(--text);
  line-height: 1.75;
}
.dif-cell-quote cite {
  display: block;
  margin-top: .8rem;
  font-family: var(--mono);
  font-size: .62rem;
  font-weight: 300;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--muted-2);
  font-style: normal;
}

/* ── CÓMO FUNCIONA ── */
.como-block { max-width: 1100px; margin: 0 auto; }
.como-header {
  margin-bottom: 3.5rem;
  display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: end;
}
.como-flow {
  display: grid; grid-template-columns: repeat(5, 1fr);
  gap: 0;
}
.como-step {
  padding: 2rem 1.5rem;
  border: 1px solid var(--border);
  border-right: none;
  position: relative;
  background: var(--bg);
  transition: background .25s;
}
.como-step:last-child { border-right: 1px solid var(--border); }
.como-step:hover { background: var(--bg-3); }
.como-step-num {
  font-family: var(--mono);
  font-size: .58rem;
  font-weight: 300;
  letter-spacing: .14em;
  color: var(--muted-2);
  margin-bottom: 1.5rem;
}
.como-step-icon {
  font-size: 1.1rem;
  margin-bottom: 1rem;
  line-height: 1;
  color: var(--muted-2);
  transition: color .3s;
}
.como-step:hover .como-step-icon { color: var(--accent); }
.como-step-title {
  font-family: var(--mono);
  font-size: .8rem;
  font-weight: 600;
  color: var(--text);
  margin-bottom: .6rem;
  line-height: 1.3;
}
.como-step-desc { font-size: .75rem; color: var(--muted); line-height: 1.7; }
.como-step-arrow {
  position: absolute; right: -10px; top: 50%;
  transform: translateY(-50%);
  font-family: var(--mono);
  font-size: .75rem;
  color: var(--accent);
  z-index: 2;
  background: var(--bg);
  padding: 2px 0;
}
.como-step:last-child .como-step-arrow { display: none; }
.como-note {
  margin-top: 2rem;
  padding: 1.5rem 2rem;
  border: 1px solid var(--border);
  background: var(--bg-2);
  display: flex; align-items: center; gap: 2rem;
  flex-wrap: wrap;
}
.como-note-text {
  font-family: var(--mono);
  font-size: .72rem;
  font-weight: 300;
  color: var(--muted);
  letter-spacing: .04em;
  flex: 1;
}
.como-note-text strong { color: var(--accent); font-weight: 600; }
.como-note-logo { width: 32px; height: 26px; opacity: .25; flex-shrink: 0; }

/* ── TECNOLOGÍA ── */
.ia-block {
  max-width: 1100px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;
}
.ia-visual {
  border: 1px solid var(--border);
  background: var(--bg-2);
  overflow: hidden;
}
.ia-visual-header {
  padding: .7rem 1.2rem;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: .5rem;
}
.ia-visual-dot { width: 7px; height: 7px; border-radius: 50%; }
.ia-visual-dot.g { background: #60c860; }
.ia-visual-dot.y { background: #c8b060; }
.ia-visual-dot.r { background: #c86060; }
.ia-visual-title {
  font-family: var(--mono);
  font-size: .6rem;
  font-weight: 300;
  letter-spacing: .14em;
  color: var(--muted-2);
  text-transform: uppercase;
  margin-left: .5rem;
}
.ia-terminal {
  font-family: var(--mono);
  font-size: .72rem;
  line-height: 1.9;
  color: var(--muted);
  padding: 1.5rem;
}
.ia-terminal .prompt { color: var(--accent); }
.ia-terminal .ok { color: #60c860; }
.ia-terminal .warn { color: #c8b060; }
.ia-terminal .comment { color: var(--muted-2); }
.ia-terminal .cursor {
  display: inline-block;
  width: 7px; height: 13px;
  background: var(--accent);
  vertical-align: middle;
  animation: blink .9s step-end infinite;
}
@keyframes blink { 50% { opacity: 0; } }

.ia-metrics {
  margin-top: 1px;
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; background: var(--border);
  border: 1px solid var(--border); border-top: none;
}
.ia-metric { background: var(--bg-3); padding: 1rem 1.2rem; text-align: center; }
.ia-metric-num {
  font-family: var(--mono);
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--text);
  line-height: 1;
}
.ia-metric-num span { color: var(--accent); font-size: .8em; }
.ia-metric-label {
  font-family: var(--mono);
  font-size: .55rem;
  font-weight: 300;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--muted-2);
  margin-top: .3rem;
}

.ia-list { margin-top: 2rem; display: flex; flex-direction: column; gap: 1.2rem; }
.ia-feature {
  display: flex; gap: 1rem; align-items: flex-start;
  padding: 1.2rem;
  border: 1px solid var(--border);
  background: var(--bg-2);
  transition: border-color .2s;
}
.ia-feature:hover { border-color: var(--border-2); }
.ia-feature-icon { font-size: 1rem; flex-shrink: 0; margin-top: .1rem; width: 28px; text-align: center; }
.ia-feature-text { font-size: .82rem; color: var(--muted); line-height: 1.65; }
.ia-feature-text strong {
  font-weight: 400;
